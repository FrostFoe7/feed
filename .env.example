# ─── Appwrite Core ────────────────────────────────────────────
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=threads_db
APPWRITE_STORAGE_BUCKET_ID=post_images

# ─── Appwrite Collections ─────────────────────────────────────
APPWRITE_COLLECTION_USERS=users
APPWRITE_COLLECTION_POSTS=posts
APPWRITE_COLLECTION_LIKES=likes
APPWRITE_COLLECTION_REPOSTS=reposts
APPWRITE_COLLECTION_FOLLOWS=follows
APPWRITE_COLLECTION_NOTIFICATIONS=notifications
APPWRITE_COLLECTION_REPORTS=reports

# ─── Appwrite Storage Buckets ─────────────────────────────────
APPWRITE_BUCKET_AVATARS=avatars
APPWRITE_BUCKET_POST_IMAGES=post_images

# ─── Application Settings ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Generated via `openssl rand -base64 32`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Admin ────────────────────────────────────────────────────
ADMIN_USER_ID=
